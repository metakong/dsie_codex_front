# Jungle API — the AI engine backend (FastAPI on Hetzner or localhost for dev)
JUNGLE_API_URL=http://127.0.0.1:8000
JUNGLE_SECRET_KEY=

# Anthropic API key — NOT used directly by the frontend.
# Kept here as a placeholder only; inference runs in the Jungle.
ANTHROPIC_API_KEY=

# Cal.com booking embed username
NEXT_PUBLIC_CAL_USERNAME=dsiecodex

# Lemon Squeezy store slug
NEXT_PUBLIC_LEMON_SQUEEZY_STORE=thedsiecodex

